#!/bin/bash

# Get the current branch name
BRANCH_NAME=$(git symbolic-ref --short HEAD)

# Exit if branch name is empty (e.g., during rebase)
[ -z "$BRANCH_NAME" ] && exit 0

# Branches to skip
SKIP_BRANCHES=("main" "master" "develop" "release")
for branch in "${SKIP_BRANCHES[@]}"; do
  [ "$BRANCH_NAME" = "$branch" ] && exit 0
done

# Remove any prefix before slash (e.g., feature/ABCD-1234 → ABCD-1234)
[[ "$BRANCH_NAME" == */* ]] && BRANCH_NAME="${BRANCH_NAME#*/}"

# Extract story ID:
# - Match letter-prefix + dash + number (ABCD-1234)
# - Or just digits at the start (14-branch-name → 14)
if [[ "$BRANCH_NAME" =~ ^([A-Za-z]+-[0-9]+|[0-9]+) ]]; then
  STORY_ID="\#${BASH_REMATCH[1]}"
else
  STORY_ID="$BRANCH_NAME"
fi

# Exit if the commit message already contains the story ID
grep -Fq "[$STORY_ID]" "$1" && exit 0

# Prepend the story ID to the commit message
echo $STORY_ID
sed -i "1s/^/[$STORY_ID] /" "$1"
