#!/bin/bash

# Usage: ./script.sh [remote_ip]
# Example: ./script.sh 192.168.1.50

REMOTE_HOST="${1:-${OLLAMA_HOST:-http://localhost:11434}}"
export OLLAMA_HOST="$REMOTE_HOST"
export OLLAMA_API_BASE="$REMOTE_HOST"

echo "🔌 Connecting to Ollama at: $REMOTE_HOST"

# Function to list models
get_ollama_models() {
    # Fetch models from the specified host
    models=($(ollama list | awk 'NR>1 {print $1}'))

    if [ ${#models[@]} -eq 0 ]; then
        echo "❌ No Ollama models found at $REMOTE_HOST."
        exit 1
    fi

    echo "🔍 Available models:"
    for i in "${!models[@]}"; do
        echo "  $((i+1))) ${models[$i]}"
    done
}

get_ollama_models

read -p "👉 Select a model by entering its number: " choice

# Validate input
if ! [[ "$choice" =~ ^[0-9]+$ ]]; then
    echo "❌ Invalid input. Please enter a valid number."
    exit 1
fi

choice=$((choice - 1))

if [ "$choice" -lt 0 ] || [ "$choice" -ge "${#models[@]}" ]; then
    echo "❌ Invalid selection."
    exit 1
fi

selected_model=${models[$choice]}

echo "🚀 Running Aider with model: ollama/${selected_model} (via $REMOTE_HOST)"
# Pass the host to aider if it supports it, or rely on the exported env var
aider --model "ollama/${selected_model}" --timeout 86400
